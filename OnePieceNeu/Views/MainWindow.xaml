<Window x:Class="OnePieceNeu.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OnePieceNeu"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Background>
        <ImageBrush ImageSource="pack://application:,,,/Assets/OPBackground.jpg" Stretch="UniformToFill"/>
    </Window.Background>
    <StackPanel>
        <TextBox Name="Header" Text="One Piece Quiz" BorderBrush="Transparent" Foreground="DarkRed" FontSize="50" FontWeight="Bold" TextAlignment="Center" Width="800" Height="104" HorizontalAlignment="Center" Background="Transparent" />
        <Button Click="Start_Click"  Content="Start" FontWeight="DemiBold" BorderBrush="DarkRed" Background="#FFF1F19F" Foreground="DarkRed" FontSize="30" Margin="0,0,0,30" Height="70" Width="200"></Button>
        <Button Click="Beenden_Click" Content="Beenden" FontWeight="DemiBold" BorderBrush="DarkRed" Background="#FFF1F19F" Foreground="DarkRed" FontSize="30" Margin="0,0,0,30" Height="70" Width="200"></Button>
    </StackPanel>
</Window>
