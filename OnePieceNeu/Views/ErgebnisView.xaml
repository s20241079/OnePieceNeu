<UserControl x:Class="OnePieceNeu.Views.ErgebnisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OnePieceNeu.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/assets/OPBackground2.jpg" Stretch="UniformToFill" />
        </Grid.Background>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="500">

            <TextBlock Text="QUIZ BEENDET" FontSize="60" FontWeight="Bold" Foreground="DarkRed" 
                       HorizontalAlignment="Center" Margin="0,0,0,20">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="2" Color="Black"/>
                </TextBlock.Effect>
            </TextBlock>

            <TextBlock Text="{Binding ErgebnisText}" FontSize="30" Foreground="Black" 
                       HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <TextBlock Text="Trage deinen Namen in die Highscore-Liste ein:" FontSize="18" Margin="0,0,0,5"/>
            <TextBox Text="{Binding SpielerName, UpdateSourceTrigger=PropertyChanged}" 
                     FontSize="24" Height="45" VerticalContentAlignment="Center" 
                     Margin="0,0,0,20" TextAlignment="Center"/>

            <Button Command="{Binding SpeichernUndHighscoreCommand}" 
        Content="Punkte Speichern" 
        Height="60" 
        FontSize="24" 
        FontWeight="Bold"
        Background="#FFF1F19F" 
        Foreground="DarkRed" 
        BorderBrush="DarkRed" />

        </StackPanel>
    </Grid>
</UserControl>
